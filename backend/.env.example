# Aegis Edge backend configuration.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# === LLM (Ollama running on the DGX Spark) ===
# Replace with the Spark's Tailscale IP, e.g. http://100.64.1.23:11434
OLLAMA_URL=http://localhost:11434

# Two-stage pipeline: the analyst reasons about the attack, then the coder
# synthesises the firmware patch. Use the exact tags from `ollama list`.
OLLAMA_ANALYSIS_MODEL=llama3.1:70b
OLLAMA_CODER_MODEL=qwen2.5-coder:32b

# Set to true to bypass Ollama and emit the deterministic fallback patch
# (useful when offline or rehearsing without the Spark reachable).
FORCE_FALLBACK_LLM=false

# === Hardware bridge ===
# Set to false once an Arduino is plugged in.
SIMULATE_SERIAL=true
SIMULATE_FLASH=true
SERIAL_PORT=/dev/ttyUSB0
